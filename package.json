{
  "name": "limey",
  "version": "2.0.0",
  "description": "A Discord bot that logs everything happening in a server with a web dashboard",
  "main": "dist/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "start:worker": "node src/worker.js",
    "dev:worker": "node --watch src/worker.js",
    "build": "node scripts/build.js",
    "start:prod": "node dist/index.js"
  },
  "keywords": [
    "discord",
    "bot"
  ],
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.27.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "javascript-obfuscator": "^5.5.0",
    "jimp": "^1.6.1"
  },
  "overrides": {
    "undici": "^6.27.0"
  },
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Limey-Team/limey-discord-bot.git"
  },
  "author": "",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Limey-Team/limey-discord-bot/issues"
  },
  "homepage": "https://github.com/Limey-Team/limey-discord-bot#readme"
}
