# ═══════════════════════════════════════════════════════════════════════
# Limey Discord Bot — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required: DISCORD_TOKEN
# Everything else is optional depending on which features you use.
# ═══════════════════════════════════════════════════════════════════════

# ─── Core Bot (REQUIRED) ──────────────────────────────────────────────

# Your bot's token from the Discord Developer Portal.
# Go to https://discord.com/developers/applications → your app → Bot → Reset Token
DISCORD_TOKEN=your_bot_token_here

# ─── Sharding (Required for Distributed Mode) ─────────────────────────
# The main server runs shard 0 locally. Worker shard servers register via
# HTTP to get assigned shards 1, 2, 3...
#
# IMPORTANT: This must be a fixed number! Discord.js uses
#   (guildId >> 22) % shardCount
# to determine which shard owns a guild. Changing this after shards are
# running will re-map guilds to different shards.
#
# Set this to the TOTAL number of shards (including shard 0 on main server).
# Default: 2 (shard 0 local + 1 worker slot)
# SHARD_COUNT=2

# ─── OAuth Dashboard (Optional — enables login wall) ───────────────────

# Discord app client ID for OAuth login.
# Found at https://discord.com/developers/applications → your app → OAuth2 → Client ID
# DISCORD_CLIENT_ID=your_client_id_here

# Discord app client secret for OAuth login.
# Found at https://discord.com/developers/applications → your app → OAuth2 → Client Secret
# DISCORD_CLIENT_SECRET=your_client_secret_here

# Your personal Discord user ID — grants full dashboard access to ALL guilds
# the bot is in, plus owner-only slash commands.
# BOT_OWNER_ID=your_discord_user_id_here

# Base URL for OAuth redirect (must match the redirect URI you set in the
# Discord Developer Portal under OAuth2 → Redirects).
# Default: http://localhost:3000
# DASHBOARD_URL=http://localhost:3000

# Port for the web dashboard server.
# Default: 3000
# WEB_PORT=3000

# ─── Git Sync (Optional — enables persistent data on ephemeral filesystems) ─

# GitHub Personal Access Token (classic) with repo write access.
# Create one at https://github.com/settings/tokens
# Required for git-sync to commit config changes back to your repo.
# GITHUB_TOKEN=your_github_pat_here

# GitHub repository to push to, e.g. "username/repo".
# If not set, auto-detected from the git remote origin URL.
# GITHUB_REPO=username/repo

# Branch to push git-sync commits to.
# Default: main
# GITHUB_BRANCH=main

# ─── Auto-Update (Optional — requires Git Sync) ───────────────────────

# Set to 'true' to automatically pull new code from GitHub and restart
# whenever new commits are detected on the branch.
# GIT_AUTO_UPDATE=false

# How often (in milliseconds) to poll GitHub for new commits.
# Default: 60000 (60 seconds)
# GIT_POLL_INTERVAL=60000

# ─── Vote Webhooks (Optional) ─────────────────────────────────────────

# Webhook secret from Top.gg for HMAC verification of vote notifications.
# Found in your bot's management page on Top.gg.
# TOPGG_WEBHOOK_SECRET=your_topgg_webhook_secret

# Webhook secret from DiscordBotList.com for Authorization header verification
# of vote notifications.
# DBL_WEBHOOK_SECRET=your_dbl_webhook_secret

# ─── Discord Bot List API (Optional — stats & command sync) ────────────

# API token from DiscordBotList.com for auto-posting guild/user stats
# and syncing slash commands to your bot's profile page.
# Find it at https://discordbotlist.com/ under your bot's management page.
# DBL_API_TOKEN=your_dbl_api_token_here

# ─── Distributed Sharding (Optional — for worker shard servers) ────────
# These are used by WORKER shard servers (src/worker.js), not the main server.
# Worker servers register with the coordinator on the main server to get
# assigned a shard ID and send heartbeats.

# URL of the main server's coordinator API (the main server's base URL).
# Worker servers use this to register and send heartbeats.
# COORDINATOR_URL=https://limey-discord-bot.onrender.com

# This worker's public URL (so the coordinator can reach this shard's HTTP
# endpoints for guild/user lookups). If not set, the coordinator won't be
# able to route requests to this shard directly.
# WORKER_URL=https://my-worker-server.example.com

# Port for the worker's minimal HTTP server (health, stats, guild lookup).
# Default: 3000 + assigned shard ID (e.g., shard 1 = port 3001)
# WORKER_PORT=3001

# How often (in milliseconds) to send heartbeats to the coordinator.
# Default: 30000 (30 seconds)
# WORKER_HEARTBEAT_INTERVAL=30000


# ─── Master API Key (Required for Distributed Sharding) ───────────────
# A shared secret that worker shard servers use to authenticate with the
# main server's coordinator. Must be the same on the main server and all
# worker servers. Set this to a long, random string.
# MASTER_API_KEY=your_shared_secret_here


# ─── Custom Bot Tokens (Optional) ──────────────────────────────────────

# For running additional custom bot instances alongside the main bot.
# Format: BOT_TOKEN_<GUILD_ID>=<token>
# Replace <GUILD_ID> with the Discord server ID where the bot should run.
# Tokens are kept in memory only — never written to disk.
# Example:
# BOT_TOKEN_123456789012345678=another_bot_token_here
