# ═══════════════════════════════════════════════════════════════════════════════
# Limey — Discord Moderation, Logging & Management Bot
# Environment Variables — Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Required ─────────────────────────────────────────────────────────────────

# Your bot's Discord token (from Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=your_bot_token_here


# ─── Discord OAuth for Dashboard ─────────────────────────────────────────────
# Optional — enables login wall on the web dashboard.
# Set these, then add http://localhost:3000/auth/callback as a redirect URI
# in the Discord Developer Portal → OAuth2.

# Discord app client ID (from Developer Portal → OAuth2 → General)
DISCORD_CLIENT_ID=
# Discord app client secret (from Developer Portal → OAuth2 → General)
DISCORD_CLIENT_SECRET=

# Your Discord user ID — grants full dashboard access + owner-only commands
BOT_OWNER_ID=

# Public URL where the dashboard is hosted (for OAuth redirects)
# Default: http://localhost:3000
DASHBOARD_URL=http://localhost:3000


# ─── Git Sync (Persistent Data) ──────────────────────────────────────────────
# # Auto-commits config changes to GitHub so data survives restarts.

# GitHub Personal Access Token (classic) with repo write access
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# GitHub repo to push to, e.g. "username/repo"
# If not set, auto-detected from git remote origin
GITHUB_REPO=

# Branch to push to (default: main)
GITHUB_BRANCH=main

# Set to "true" to auto-restart the bot when new code is pushed to GitHub
GIT_AUTO_UPDATE=false

# How often (in ms) to check for new commits when auto-update is enabled
# Default: 60000 (60 seconds)
GIT_POLL_INTERVAL=60000


# ─── Vote Webhooks ───────────────────────────────────────────────────────────
# Optional — enables vote notification handling from bot lists.

# Webhook secret from Top.gg (HMAC-SHA256 verification for vote notifications)
TOPGG_WEBHOOK_SECRET=

# Webhook secret from DiscordBotList.com (Authorization header verification)
DBL_WEBHOOK_SECRET=


# ─── Deployment ──────────────────────────────────────────────────────────────
# Optional — enables the "Restart Server" button in the dashboard.

# 
# ─── Sharding ─────────────────────────────────────────────────────────────────
# Discord.js Sharding splits the bot across multiple processes for large servers
# (recommended for 2000+ guilds). Each shard handles a subset of guilds.
#
# Set to a number (e.g. 2) for manual shard count, or leave blank for 'auto'
# (discord.js calculates based on Discord's recommendation for your guild count)
# SHARD_COUNT=auto


# ─── Server Configuration ────────────────────────────────────────────────────

# Port for the web dashboard (default: 3000)
WEB_PORT=3000


# ─── Build System ────────────────────────────────────────────────────────────
# Production builds use javascript-obfuscator with:
#   - Debug protection (anti step-through debugging)
#   - Self-defending (code breaks if beautified)
#   - Control flow flattening, dead code injection, RC4 string encoding
# See scripts/build.js for all options.
# Run: npm run build && npm run start:prod


# ─── Custom Bot Token Persistence ────────────────────────────────────────────
# For each custom bot you manage via the dashboard, add an env var like:
#   BOT_TOKEN_GUILDID=<bot_token>
# Replace GUILDID with the actual Discord server (guild) ID.
# This makes the bot survive redeploys.
#
# Example:
# BOT_TOKEN_123456789012345678=another_bot_token_here
